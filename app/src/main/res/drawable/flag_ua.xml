<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="28dp"
        android:height="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#1F57A4" />
            <stroke
                android:width="1dp"
                android:color="#334455" />
        </shape>
    </item>

    <item
        android:width="28dp"
        android:height="20dp"
        android:top="10dp">
        <shape android:shape="rectangle">
            <size android:height="10dp" />
            <solid android:color="#F2C94C" />
        </shape>
    </item>
</layer-list>
