<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="UREDI POSTAJO"
            android:textColor="#F4F7FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Polno ime"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtEditStationName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stream URL"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtEditStationUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Country"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtEditStationCountry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Genre"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtEditStationGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Napis na tipki"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editButtonLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:inputType="textMultiLine"
            android:minHeight="56dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#8E99A3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stran"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editPage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:inputType="number"
            android:minHeight="56dp"
            android:padding="16dp"
            android:textColor="#F4F7FA" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pozicija"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/editPosition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:inputType="number"
            android:minHeight="56dp"
            android:padding="16dp"
            android:textColor="#F4F7FA" />

        <CheckBox
            android:id="@+id/checkVisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="VIDNO"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveStationEdit"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3E7C4A"
            android:text="SHRANI"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDeleteStation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#A64040"
            android:text="IZBRI&#x0160;I POSTAJO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackStationEdit"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:backgroundTint="#2F5F9E"
            android:text="NAZAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
