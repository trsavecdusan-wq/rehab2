<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="NASTAVITVE"
            android:textColor="#F4F7FA"
            android:textSize="32sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackSettings"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2F5F9E"
            android:text="NAZAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRadioSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#214A78"
            android:text="Radio nastavitve"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3A3F45"
            android:text="AAC nastavitve"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStatusSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#3A3F45"
            android:text="Status nastavitve"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackupSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#214A78"
            android:text="Nadgradnje"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="NAPAJANJE"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="POWER ZAŠČITA"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeOff"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#3A3F45"
            android:text="IZKLOPLJENA"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeWarning"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#3A3F45"
            android:text="OPOZORILO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeSleep"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#3A3F45"
            android:text="AVTOMATSKI SLEEP"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/keep_screen_on_charging_label"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnKeepScreenOnWhileCharging"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#3A3F45"
            android:text="@string/keep_screen_on_charging_enabled"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="KOLIKO ČASA BREZ NAPAJANJA"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAllowedUnplugMinus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="-"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAllowedUnplugValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="15 MIN"
                android:textColor="#F4F7FA"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAllowedUnplugPlus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="+"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="KRITIČNA BATERIJA"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCriticalBatteryMinus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="-"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCriticalBatteryValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="20 %"
                android:textColor="#F4F7FA"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCriticalBatteryPlus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="+"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="OPOZORILO PRED SLEEP"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnWarningGraceMinus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="-"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtWarningGraceValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="5 MIN"
                android:textColor="#F4F7FA"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWarningGracePlus"
                android:layout_width="110dp"
                android:layout_height="76dp"
                android:background="#00000000"
                android:gravity="center"
                android:text="+"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="STATUS"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPowerStatusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="NAPAJANJE PRIKLOPLJENO"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="STATISTIKA GPS"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="DANES"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTodayDistanceValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="0 M"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="SKUPAJ"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtTotalDistanceValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="0 M"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="@string/gps_diagnostics_title"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/gps_signal_label"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtGpsSignalValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="WEAK"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/gps_accuracy_label"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtGpsAccuracyValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="-"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/gps_last_ignored_reason_label"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtGpsIgnoredReasonValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="NONE"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnResetGpsStatistics"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#A64040"
            android:text="@string/gps_reset_button_label"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
