<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="NASTAVITVE"
        android:textColor="#F4F7FA"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackSettings"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#2F5F9E"
        android:text="NAZAJ"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnRadioSettings"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#214A78"
        android:text="Radio nastavitve"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnAacSettings"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#3A3F45"
        android:text="AAC nastavitve"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnStatusSettings"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#3A3F45"
        android:text="Status nastavitve"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackupSettings"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:backgroundTint="#214A78"
        android:text="Nadgradnje"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
