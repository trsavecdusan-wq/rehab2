<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="NASTAVITVE"
            android:textColor="#F4F7FA"
            android:textSize="32sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackSettings"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2F5F9E"
            android:text="NAZAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacSettings"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2F5F9E"
            android:text="KOMUNIKATOR"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettingsModuleVideoCalls"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="VIDEO KLICI"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettingsModuleMessages"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="SPOROČILA"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettingsModuleGallery"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="GALERIJA"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettingsModuleMirror"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="OGLEDALO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStatusSettings"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3A3F45"
            android:text="GOVOR / API"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSettingsModuleSystem"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3A3F45"
            android:text="SISTEM"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackupSettings"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_marginBottom="28dp"
            android:backgroundTint="#3A3F45"
            android:text="POSODOBITVE / VARNOSTNE KOPIJE"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sectionAdvancedSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:text="NAPREDNA ORODJA"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRadioSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="Radio nastavitve"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacPackSettings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3E7C4A"
            android:text="AAC paket (izvoz)"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCreateSampleAacPack"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2E8B57"
            android:text="USTVARI TESTNI AAC PAKET"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCheckAacFiles"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#214A78"
            android:text="PREVERI AAC DATOTEKE"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sectionSpeechApiSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="GOVOR / API"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSpeechApiStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:padding="16dp"
            android:text="API ključ: ni nastavljen"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editSpeechApiKey"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:hint="Prilepi OpenAI API ključ"
            android:inputType="textPassword"
            android:padding="16dp"
            android:singleLine="true"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/editSpeechApiBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:hint="https://api.openai.com"
            android:inputType="textUri"
            android:padding="16dp"
            android:singleLine="true"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editSpeechApiModel"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:hint="gpt-4o-mini-tts"
            android:inputType="text"
            android:padding="16dp"
            android:singleLine="true"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editSpeechApiVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="marin"
            android:inputType="text"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editSpeechApiSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="0.88"
            android:inputType="numberDecimal"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchSingleIconSpeech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Govor posamezne ikone"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editSingleIconDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="Zamik ikone: 700 ms"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchFastCompositionSkipLastIcon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Preskoči zadnjo ikono pri hitrem sestavljanju"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAutoSentenceSpeech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Samodejni govor stavka"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editAutoSentenceDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="Samodejni stavek: 3000 ms"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchReturnToRootAfterSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Po govoru stavka vrni na root meni"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchClearSentenceAfterSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Po govoru stavka izbriši sestavljeni tekst"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacGridSizeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Velikost mreže komunikatorja: 3 x 3"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editAacGridSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="3 x 3"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchPersistentTopRowEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Stalna prva vrstica"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPersistentTopRowStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Stalna prva vrstica: VKLOP"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editPersistentTopRowCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="4 ikone"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchGuidedFollowUpEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Vodena follow-up vprašanja"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchVendingNumberDisplayEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Prikaži številko pijače na avtomatu"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchSpeakDigitsSeparatelyEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Govori številko po posameznih cifrah"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVendingCodesTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="AVTOMAT – KODE PO LOKACIJI"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editVendingCodes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="Trenutna lokacija"
            android:inputType="none"
            android:maxLines="8"
            android:minHeight="96dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAacAssistTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="AI PREDLOGI – TESTNO"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacAssistStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="AI predlogi: IZKLOPLJENO"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editAacAssistInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:clickable="false"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="AI predlogi so pripravljeni, vendar še niso aktivni."
            android:inputType="none"
            android:maxLines="8"
            android:minHeight="96dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtActiveAacProfileStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Aktivni AAC profil: DOM"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editActiveAacProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="DOM"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAacCommunicationContextStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="AAC kontekst: Normalna komunikacija"
            android:textColor="#D6DDE4"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editAacCommunicationContext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#1E2329"
            android:clickable="true"
            android:focusable="false"
            android:gravity="center_vertical"
            android:hint="Normalna komunikacija"
            android:inputType="none"
            android:maxLines="2"
            android:minHeight="60dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#9EA8B2"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchRealWorldHelpersEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:minHeight="56dp"
            android:paddingVertical="8dp"
            android:text="Real-world helperji"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveSpeechApiSettings"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#214A78"
            android:text="SHRANI API NASTAVITVE"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTestSpeechApi"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#2E8B57"
            android:text="TEST GOVORA API"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnImportSpeechApiKey"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#3A3F45"
            android:text="UVOZI API KLJUČ IZ DATOTEKE"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sectionSystemSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="NAPAJANJE"
            android:textColor="#F4F7FA"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/power_protection_title"
            android:textColor="#D6DDE4"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeOff"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#3A3F45"
            android:text="IZKLOPLJENA"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeWarning"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#3A3F45"
            android:text="OPOZORILO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPowerModeSleep"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#3A3F45"
            android:text="AVTOMATSKI SLEEP"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
