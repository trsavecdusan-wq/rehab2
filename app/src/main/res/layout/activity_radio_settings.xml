<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="RADIO NASTAVITVE"
            android:textColor="#F4F7FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackRadioSettings"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#2F5F9E"
            android:text="NAZAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPageLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="STRAN 1"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1. Radio 1"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2. Radio 2"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3. ROKS UA"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="4. Kiss FM"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5. Nashe UA"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="#1E2329"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtStationSlot6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="6. MP3"
                android:textColor="#F4F7FA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVisibleStation6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#3E7C4A"
                android:text="VIDNO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

            <Button
                android:id="@+id/btnEditStation6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#214A78"
                android:text="UREDI"
                android:textAllCaps="false"
                android:textColor="#F4F7FA" />

        </LinearLayout>

        <Button
            android:id="@+id/btnPreviousPage"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2F5F9E"
            android:text="PREJŠNJA STRAN"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNextPage"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#2F5F9E"
            android:text="NASLEDNJA STRAN"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAddStation"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="#3E7C4A"
            android:text="DODAJ POSTAJO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
