<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="TEST POSTAJE"
            android:textColor="#F4F7FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPreviewStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtPreviewName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPreviewCountry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtPreviewTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#F4F7FA"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtPreviewUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColor="#B8C0C8"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnTestStation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3E7C4A"
            android:text="TESTIRAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStopStation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#214A78"
            android:text="USTAVI"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveAssignStation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#6A4E8E"
            android:text="SHRANI / DODELI"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnBackRadioPreview"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:backgroundTint="#2F5F9E"
            android:text="NAZAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>