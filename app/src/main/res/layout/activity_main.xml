<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="8dp"
        android:background="#1A1F24"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <SeekBar
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:progressDrawable="@drawable/volume_seekbar_progress"
            android:thumb="@drawable/volume_seekbar_thumb"
            android:thumbOffset="0dp"
            android:max="100"
            android:progress="55"
            android:splitTrack="false" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="188dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="#1E2329"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="6dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="R1"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="R2"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="6dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="R3"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="R4"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="R5"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <Button
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:autoSizeMaxTextSize="18sp"
                        android:autoSizeMinTextSize="10sp"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeTextType="uniform"
                        android:backgroundTint="#34414D"
                        android:gravity="center"
                        android:maxLines="2"
                        android:padding="12dp"
                        android:text="MP3"
                        android:textAllCaps="false"
                        android:textColor="#F4F7FA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="#1E2329"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:autoSizeMaxTextSize="26sp"
                android:autoSizeMinTextSize="16sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:gravity="center"
                android:maxLines="2"
                android:text="STATUS"
                android:textColor="#F4F7FA"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="20dp"
        android:layout_weight="1"
        android:background="#1A1F24"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacZejna"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="ŽEJNA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacLacna"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="LAČNA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacPomoc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="POMOČ"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacWc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="WC"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacDobro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="DOBRO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacSlabo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="SLABO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacUtrujena"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="UTRUJENA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacMraz"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="MRAZ"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacVroce"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="VROČE"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:autoSizeMaxTextSize="18sp"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:background="#20262C"
            android:gravity="center"
            android:maxLines="1"
            android:padding="8dp"
            android:text="VIDEO"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:autoSizeMaxTextSize="18sp"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:background="#20262C"
            android:gravity="center"
            android:maxLines="1"
            android:padding="8dp"
            android:text="SLIKE"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:autoSizeMaxTextSize="18sp"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:background="#20262C"
            android:gravity="center"
            android:maxLines="1"
            android:padding="8dp"
            android:text="ZRCALO"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:autoSizeMaxTextSize="18sp"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeStepGranularity="1sp"
            android:autoSizeTextType="uniform"
            android:background="#20262C"
            android:gravity="center"
            android:maxLines="1"
            android:padding="8dp"
            android:text="MIR"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
