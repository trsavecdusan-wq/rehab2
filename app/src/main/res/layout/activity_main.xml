<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="8dp"
        android:background="#1A1F24"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <SeekBar
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:progressDrawable="@drawable/volume_seekbar_progress"
            android:thumb="@drawable/volume_seekbar_thumb"
            android:thumbOffset="0dp"
            android:max="100"
            android:progress="55"
            android:splitTrack="false" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:layout_weight="1.15"
            android:background="#1E2329"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="1dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="Radio&#10;1"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="Radio&#10;2"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="1dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="ROKS&#10;UA"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="Kiss&#10;FM"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="Nashe&#10;UA"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="1dp"
                        android:layout_weight="1"
                        android:background="#2F5F9E"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:padding="2dp"
                        android:text="MP3"
                        android:textColor="#F4F7FA"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:layout_weight="0.85"
            android:background="#214A78"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇸🇮"
                    android:textColor="#F4F7FA"
                    android:textSize="16sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="100%"
                    android:textColor="#F4F7FA"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#6FD38A"
                    android:textSize="14sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="bottom|start"
                    android:orientation="vertical">

                    <Space
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Torek"
                        android:textColor="#B8C0C8"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.05."
                        android:textColor="#B8C0C8"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026"
                        android:textColor="#8E99A3"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <Space
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="5"
                        android:textColor="#F4F7FA"
                        android:textSize="44sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="1dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="20dp"
        android:layout_weight="1"
        android:background="#1A1F24"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacZejna"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="ŽEJNA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacLacna"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="LAČNA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacPomoc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="POMOČ"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacWc"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="WC"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacDobro"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="DOBRO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacSlabo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="SLABO"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#232A31"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnAacUtrujena"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="UTRUJENA"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacMraz"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="MRAZ"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAacVroce"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="#34414D"
                android:gravity="center"
                android:maxLines="1"
                android:padding="8dp"
                android:text="VROČE"
                android:textAllCaps="false"
                android:textColor="#F4F7FA"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#2F5F9E"
            android:gravity="center"
            android:maxLines="1"
            android:padding="6dp"
            android:text="VIDEO"
            android:textColor="#F4F7FA"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#3E7C4A"
            android:gravity="center"
            android:maxLines="1"
            android:padding="6dp"
            android:text="GALERIJA"
            android:textColor="#F4F7FA"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="#2F7C86"
            android:gravity="center"
            android:maxLines="1"
            android:padding="6dp"
            android:text="OGLEDALO"
            android:textColor="#F4F7FA"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="#6A4E8E"
            android:gravity="center"
            android:maxLines="1"
            android:padding="6dp"
            android:text="SPROSTITEV"
            android:textColor="#F4F7FA"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
