<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#121417">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <ImageView
            android:id="@+id/imgAacEditorPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:adjustViewBounds="true"
            android:background="#263746"
            android:contentDescription=""
            android:padding="8dp"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/txtAacEditorItemId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#DCE6EF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorSpeech"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#F4F7FA"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtAacEditorImagePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#DCE6EF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtAacEditorHiddenStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#F2C94C"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorChangeImage"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#34414D"
            android:text="MENJAJ SLIKO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorImageSourceHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Najprej izberite vir slike. Za osebne fotografije uporabite OSEBE / PACIENT. Za svoje slike uporabite MOJE SLIKE."
            android:textColor="#C8D0D8"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtAacEditorImageSourceChoices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B2530"
            android:padding="12dp"
            android:text="SISTEMSKE IKONE — bundled/default app icons&#10;MOJE SLIKE — NovaRehab/icons/custom/&#10;OSEBE / PACIENT — NovaRehab/icons/patient/&#10;SOČA — NovaRehab/icons/soca/&#10;ARASAAC — NovaRehab/icons/arasaac/"
            android:textColor="#F4F7FA"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/txtAacEditorGalleryHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Izberite fotografijo ali sliko iz tablice. Aplikacija jo bo shranila za to ikono."
            android:textColor="#C8D0D8"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnAacEditorPickGalleryImage"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2F5F9E"
            android:text="IZBERI SLIKO IZ GALERIJE"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorCameraHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Fotografirajte predmet ali osebo in aplikacija bo sliko shranila za to ikono."
            android:textColor="#C8D0D8"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnAacEditorCapturePhoto"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2F7A54"
            android:text="FOTOGRAFIRAJ"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorRemoveImageHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Odstranitev slike ne izbriše datoteke, samo odstrani povezavo iz te ikone."
            android:textColor="#C8D0D8"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnAacEditorRemoveImage"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#6A3840"
            android:text="ODSTRANI SLIKO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorCopyIcon"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#34414D"
            android:text="KOPIRAJ IKONO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorToggleHidden"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#8A5A2B"
            android:text="SKRIJ IKONO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAacEditorChildrenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="PODIKONE"
            android:textColor="#F4F7FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/aacEditorChildrenList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnAacEditorAddChild"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2E8B57"
            android:text="DODAJ OBSTOJEČO IKONO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorAddNewChild"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2E8B57"
            android:text="DODAJ NOVO PODIKONO"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorEditLabel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2F5F9E"
            android:text="UREDI TEKST"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAacEditorEditSpeech"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2F5F9E"
            android:text="UREDI GOVOR"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
