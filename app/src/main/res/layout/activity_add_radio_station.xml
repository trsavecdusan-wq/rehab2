<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="DODAJ POSTAJO"
        android:textColor="#F4F7FA"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackAddRadioStation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#2F5F9E"
        android:text="NAZAJ"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByCountry"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#214A78"
        android:text="PO DRŽAVI"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByGenre"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#214A78"
        android:text="PO ŽANRU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByName"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:backgroundTint="#214A78"
        android:text="PO IMENU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>