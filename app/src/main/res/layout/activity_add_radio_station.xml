<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="DODAJ POSTAJO"
        android:textColor="#F4F7FA"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackAddRadioStation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#2F5F9E"
        android:text="NAZAJ"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/editSearchQuery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1E2329"
            android:hint="Vpi&#x0161;i dr&#x017E;avo, &#x017E;anr ali ime"
            android:inputType="text"
            android:minHeight="56dp"
            android:padding="16dp"
            android:textColor="#F4F7FA"
            android:textColorHint="#8E99A3" />

        <Button
            android:id="@+id/btnClearSearch"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:backgroundTint="#6A4E8E"
            android:text="PO&#x010C;ISTI"
            android:textAllCaps="false"
            android:textColor="#F4F7FA"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSearchByCountry"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#214A78"
        android:text="PO DR&#x017D;AVI"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/countryPresetsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <Button
        android:id="@+id/btnAddCountryPreset"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#3A3F45"
        android:text="DODAJ DR&#x017D;AVO"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByGenre"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#214A78"
        android:text="PO &#x017D;ANRU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/genrePresetsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <Button
        android:id="@+id/btnSearchByName"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#214A78"
        android:text="PO IMENU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnLocalMusic"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#3E7C4A"
        android:text="LOKALNA GLASBA"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSearchStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColor="#F4F7FA"
        android:textSize="16sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
