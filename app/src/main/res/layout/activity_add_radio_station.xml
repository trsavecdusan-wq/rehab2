<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121417"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="DODAJ POSTAJO"
        android:textColor="#F4F7FA"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnBackAddRadioStation"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#2F5F9E"
        android:text="NAZAJ"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editSearchQuery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#1E2329"
        android:hint="Vpi&#x0161;i dr&#x017E;avo, &#x017E;anr ali ime"
        android:inputType="text"
        android:minHeight="56dp"
        android:padding="16dp"
        android:textColor="#F4F7FA"
        android:textColorHint="#8E99A3" />

    <Button
        android:id="@+id/btnSearchByCountry"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#214A78"
        android:text="PO DR&#x017D;AVI"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByGenre"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#214A78"
        android:text="PO &#x017D;ANRU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSearchByName"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#214A78"
        android:text="PO IMENU"
        android:textAllCaps="false"
        android:textColor="#F4F7FA"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSearchStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:textColor="#F4F7FA"
        android:textSize="16sp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>